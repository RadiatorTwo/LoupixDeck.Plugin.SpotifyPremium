<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Resolves LoupixDeck.PluginSdk from the sibling SDK repo's local feed.
       Clone LoupixDeck.PluginSdk next to this repository and build it once. -->
  <packageSources>
    <add key="LoupixDeck.PluginSdk (local)" value="..\LoupixDeck.PluginSdk\nupkg" />
  </packageSources>
</configuration>
